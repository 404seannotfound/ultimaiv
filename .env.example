# ultimaiv — environment template.
# Copy to .env and fill in real values. .env is gitignored. chmod 600 recommended.

# --- LLM providers (dialog / dynamic narration) ---
XAI_API_KEY=                   # Grok (x.ai)
GEMINI_API_KEY=                # Google AI Studio
OPENAI_API_KEY=                # OpenAI
ANTHROPIC_API_KEY=             # Anthropic (optional)

# --- Voice / TTS ---
ELEVENLABS_API_KEY=            # ElevenLabs (gypsy + NPC voices)

# Per-voice IDs (created in the ElevenLabs library; fill in once chosen).
ELEVENLABS_VOICE_GYPSY=
ELEVENLABS_VOICE_NARRATOR=
ELEVENLABS_VOICE_LB=           # Lord British (post-creation hook)

# --- Image generation (card art, wagon interior, portraits) ---
# Pick at least one. Grok image gen is cheapest at ~$0.10/image.
XAI_IMAGE_MODEL=grok-imagine-image
GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
OPENAI_IMAGE_MODEL=gpt-image-1

# --- Cloudflare (Pages + D1 deploy target) ---
# Mint at: https://dash.cloudflare.com/profile/api-tokens
# Scope: "Account → Cloudflare Pages → Edit" + "Account → D1 → Edit"
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Pages project (create in dashboard before first deploy).
PAGES_PROJECT=ultimaiv
PAGES_URL=https://ultimaiv.pages.dev/

# D1 database (create with: wrangler d1 create ultimaiv)
D1_DATABASE_NAME=ultimaiv
D1_DATABASE_ID=

# --- R2 (optional — audio + image asset bucket) ---
R2_BUCKET=ultimaiv-assets
R2_PUBLIC_URL=

# --- GitHub ---
GITHUB_OWNER=404seannotfound
GITHUB_REPO=ultimaiv

# --- Discord (/cast slash command) ---
# Mint at https://discord.com/developers/applications → New Application
# DISCORD_PUBLIC_KEY also needs to be set as a Cloudflare Pages secret:
#   wrangler pages secret put DISCORD_PUBLIC_KEY --project-name ultimaiv
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
